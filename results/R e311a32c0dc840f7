<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TrueVitals Report</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#09090b;--surface:#141416;--surface2:#1c1c1f;--surface3:#242428;
--border:#27272a;--border2:#3f3f46;
--text:#fafafa;--text2:#a1a1aa;--text3:#71717a;
--green:#2ce4ad;--green-dim:rgba(44,228,173,0.12);--green-mid:rgba(44,228,173,0.25);
--red:#ef4444;--red-dim:rgba(239,68,68,0.12);
--yellow:#a3d250;--yellow-dim:rgba(163,210,80,0.12);
--blue:#818cf8;--blue-dim:rgba(129,140,248,0.12);
--radius:12px;--radius-sm:8px;
}
html{scroll-behavior:smooth;background:var(--bg)}
body{font-family:'Outfit',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(9,9,11,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between}
.nav-brand{display:flex;align-items:center;gap:12px}
.nav-logo{font-size:20px;font-weight:700;letter-spacing:-0.5px}
.nav-logo span{color:var(--green)}
.nav-patient{font-size:13px;color:var(--text3);padding-left:12px;border-left:1px solid var(--border)}
.nav-links{display:flex;gap:4px}
.nav-links a{color:var(--text3);text-decoration:none;font-size:13px;font-weight:500;padding:8px 14px;border-radius:var(--radius-sm);transition:all 0.2s}
.nav-links a:hover,.nav-links a.active{color:var(--text);background:var(--surface2)}

/* MOBILE NAV */
.mobile-nav{display:none;position:fixed;bottom:0;left:0;right:0;z-index:100;background:rgba(9,9,11,0.95);backdrop-filter:blur(20px);border-top:1px solid var(--border);padding:8px 4px;padding-bottom:env(safe-area-inset-bottom,8px)}
.mobile-nav-inner{display:flex;justify-content:space-around}
.mobile-nav a{color:var(--text3);text-decoration:none;font-size:10px;font-weight:500;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 8px;border-radius:var(--radius-sm)}
.mobile-nav a.active{color:var(--green)}
.mobile-nav svg{width:20px;height:20px}

/* MAIN */
main{max-width:960px;margin:0 auto;padding:88px 24px 120px}
section{margin-bottom:48px}
.section-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--green);margin-bottom:16px}
.section-title{font-size:28px;font-weight:700;margin-bottom:8px;letter-spacing:-0.5px}
.section-sub{color:var(--text2);font-size:15px;margin-bottom:24px}

/* STAT CARDS */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:32px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center}
.stat-num{font-size:36px;font-weight:700;letter-spacing:-1px;margin-bottom:4px}
.stat-label{font-size:12px;color:var(--text3);font-weight:500;text-transform:uppercase;letter-spacing:0.5px}
.stat-num.green{color:var(--green)}
.stat-num.red{color:var(--red)}
.stat-num.yellow{color:#a3d250}

/* UPGRADE BANNER */
.upgrade-banner{background:var(--green-dim);border:1px solid rgba(44,228,173,0.2);border-radius:var(--radius);padding:16px 20px;margin-bottom:24px;font-size:14px;color:var(--green);line-height:1.6}

/* ANALYSIS CARDS */
.analysis-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px 28px;margin-bottom:16px}
.analysis-card h3{font-size:16px;font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.analysis-card .content{font-size:14px;color:var(--text2);line-height:1.8;white-space:pre-line}
.flag-card{border-left:3px solid var(--red)}
.rec-card{border-left:3px solid var(--blue)}
.supp-card{border-left:3px solid var(--green)}
.summary-card{border-left:3px solid var(--green)}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot.red{background:var(--red)}.dot.green{background:var(--green)}.dot.blue{background:var(--blue)}.dot.yellow{background:var(--yellow)}

/* BIOMARKER CONTROLS */
.bio-controls{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;align-items:center}
.bio-search{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 16px;color:var(--text);font-family:inherit;font-size:14px;width:260px;outline:none;transition:border-color 0.2s}
.bio-search:focus{border-color:var(--green)}
.bio-search::placeholder{color:var(--text3)}
.filter-btn{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 16px;color:var(--text3);font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s}
.filter-btn:hover{border-color:var(--border2);color:var(--text)}
.filter-btn.active{background:var(--green-dim);border-color:rgba(44,228,173,0.3);color:var(--green)}

/* BIOMARKER GROUP */
.bio-group{margin-bottom:16px}
.bio-group-header{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:all 0.2s;user-select:none}
.bio-group-header:hover{border-color:var(--border2);background:var(--surface2)}
.bio-group-header h3{font-size:14px;font-weight:600;text-transform:uppercase;letter-spacing:0.8px}
.bio-group-header .count{font-size:12px;color:var(--text3);display:flex;align-items:center;gap:8px}
.bio-group-header .chevron{transition:transform 0.3s;color:var(--text3)}
.bio-group.open .chevron{transform:rotate(180deg)}
.bio-group-body{display:none;padding:8px 0 0}
.bio-group.open .bio-group-body{display:block}

/* BIOMARKER CARD */
.bio-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:8px;overflow:hidden;transition:all 0.2s}
.bio-card:hover{border-color:var(--border2)}
.bio-card-main{padding:16px 20px;cursor:pointer;display:flex;align-items:center;gap:16px}
.bio-card-info{flex:1;min-width:0}
.bio-card-name{font-size:14px;font-weight:500;margin-bottom:2px}
.bio-card-result{font-size:13px;color:var(--text2)}
.bio-card-badge{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;flex-shrink:0;text-transform:uppercase;letter-spacing:0.5px}
.badge-red{background:var(--red-dim);color:var(--red)}
.badge-green{background:var(--green-dim);color:var(--green)}
.badge-yellow{background:var(--yellow-dim);color:var(--yellow)}
.badge-blue{background:var(--blue-dim);color:var(--blue)}

/* RANGE BAR */
.range-bar-container{flex:1;max-width:280px;min-width:160px}
.range-bar{height:6px;background:rgba(239,68,68,0.25);border-radius:3px;position:relative;overflow:visible}
.range-normal{position:absolute;height:100%;background:rgba(163,210,80,0.35);border-radius:3px;z-index:1}
.range-optimal{position:absolute;height:100%;background:rgba(44,228,173,0.5);border-radius:3px;z-index:2}
.range-dot{position:absolute;top:50%;width:12px;height:12px;border-radius:50%;transform:translate(-50%,-50%);border:2px solid var(--bg);z-index:2}
.range-dot.dot-red{background:var(--red)}
.range-dot.dot-green{background:var(--green)}
.range-dot.dot-yellow{background:#a3d250}

/* EXPANDED DETAIL */
.bio-detail{display:none;padding:0 20px 16px;border-top:1px solid var(--border)}
.bio-card.expanded .bio-detail{display:block}
.bio-detail-desc{font-size:13px;color:var(--text2);line-height:1.7;padding-top:12px;margin-bottom:12px}
.bio-detail-ranges{display:flex;gap:24px;flex-wrap:wrap;margin-bottom:12px}
.bio-detail-range{font-size:12px;color:var(--text3)}
.bio-detail-range strong{color:var(--text2)}
.bio-detail-causes{font-size:12px;color:var(--text3);line-height:1.6}
.bio-detail-causes strong{color:var(--text2);font-weight:500}

/* FOOTER */
.footer{text-align:center;padding:40px 24px;border-top:1px solid var(--border);margin-top:48px}
.footer p{font-size:12px;color:var(--text3);margin-bottom:4px}
.footer a{color:var(--green);text-decoration:none}

/* RESPONSIVE */
@media(max-width:768px){
  .nav-links{display:none}
  .mobile-nav{display:block}
  .nav-patient{display:none}
  main{padding:76px 16px 100px}
  .stats{grid-template-columns:repeat(2,1fr);gap:8px}
  .stat-num{font-size:28px}
  .section-title{font-size:22px}
  .bio-card-main{flex-wrap:wrap;gap:10px}
  .range-bar-container{max-width:100%;order:3;width:100%}
  .bio-search{width:100%}
  .bio-controls{gap:6px}
  .analysis-card{padding:20px}
}

/* SCROLL ANIMATIONS */
.fade-in{opacity:0;transform:translateY(16px);transition:opacity 0.5s,transform 0.5s}
.fade-in.visible{opacity:1;transform:translateY(0)}

/* DOB GATE */
.gate{position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:var(--bg);display:flex;align-items:center;justify-content:center}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:48px 40px;max-width:400px;width:90%;text-align:center}
.gate-logo{font-size:28px;font-weight:700;letter-spacing:-0.5px;margin-bottom:8px}
.gate-logo span{color:var(--green)}
.gate-sub{color:var(--text3);font-size:14px;margin-bottom:32px;line-height:1.5}
.gate-label{display:block;text-align:left;font-size:13px;font-weight:500;color:var(--text2);margin-bottom:8px}
.gate-input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px 16px;color:var(--text);font-family:inherit;font-size:16px;outline:none;transition:border-color 0.2s;text-align:center;letter-spacing:1px}
.gate-input:focus{border-color:var(--green)}
.gate-btn{width:100%;margin-top:16px;padding:14px;background:var(--green);color:#000;font-family:inherit;font-size:15px;font-weight:600;border:none;border-radius:var(--radius-sm);cursor:pointer;transition:opacity 0.2s}
.gate-btn:hover{opacity:0.85}
.gate-error{color:var(--red);font-size:13px;margin-top:12px;display:none}
.gate-footer{color:var(--text3);font-size:11px;margin-top:24px;line-height:1.5}
.gate-hidden{display:none}
.app-hidden{display:none}
</style>
</head>
