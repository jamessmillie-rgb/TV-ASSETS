const data = REPORT_DATA;
const bms = data.biomarkers || [];

// Stats
const totalTested = bms.filter(b => b.result && b.result !== 'Negative' && b.result !== 'Normal' && b.result !== 'To follow').length;
const abnormal = bms.filter(b => b.within_normal === 'FALSE').length;
const optimal = bms.filter(b => b.within_optimal === 'TRUE').length;
const inRange = bms.filter(b => b.within_normal === 'TRUE' && b.within_optimal !== 'TRUE').length;

// Group biomarkers
const groupOrder = ['LIVER & METABOLIC','LIPIDS & CARDIOVASCULAR','GLUCOSE & INSULIN','INFLAMMATION','ELECTROLYTES & MINERALS','KIDNEY FUNCTION','HEMATOLOGY','IRON STUDIES','HORMONES','THYROID','VITAMINS & NUTRIENTS','CARDIAC MARKERS','DIGESTIVE','IMMUNOLOGY','PROSTATE','TUMOR MARKERS','SPECIALIZED TESTS','AUTOIMMUNE & CELIAC','URINALYSIS'];
const groups = {};
bms.forEach(b => {
  if (!groups[b.group]) groups[b.group] = [];
  groups[b.group].push(b);
});

// Parse flags/recs/supps into individual items
function parseItems(text) {
  if (!text) return [];
  return text.split('\n').map(s => s.trim()).filter(s => s.length > 2).map(s => s.replace(/^[•\-]\s*/, ''));
}

const flags = parseItems(data.flags);
const recs = parseItems(data.recommendations);
const supps = parseItems(data.supplementation);

// Build page
const main = document.getElementById('main');
document.getElementById('nav-patient').textContent = data.patient_name + ' · ' + data.report_date;

let html = '';

// Upgrade banner if present in summary
let summaryText = data.summary || '';
let bannerHTML = '';
if (summaryText.toLowerCase().includes('upgraded') || summaryText.toLowerCase().includes('upgrade')) {
  const firstPara = summaryText.split('\n\n')[0];
  if (firstPara.toLowerCase().includes('upgrade')) {
    bannerHTML = `<div class="upgrade-banner">${firstPara}</div>`;
    summaryText = summaryText.substring(firstPara.length).trim();
  }
}

// OVERVIEW
html += `<section id="overview" class="fade-in">`;
html += `<div class="section-label">Overview</div>`;
html += `<div class="section-title">${data.patient_name}'s Health Report</div>`;
html += `<div class="section-sub">Report generated ${data.report_date} · ${bms.length} biomarkers analysed</div>`;
html += bannerHTML;

html += `<div class="stats">
  <div class="stat-card"><div class="stat-num">${totalTested}</div><div class="stat-label">Tested</div></div>
  <div class="stat-card"><div class="stat-num red">${abnormal}</div><div class="stat-label">Outside Range</div></div>
  <div class="stat-card"><div class="stat-num yellow">${inRange}</div><div class="stat-label">In Range</div></div>
  <div class="stat-card"><div class="stat-num green">${optimal}</div><div class="stat-label">Optimal</div></div>
</div>`;

html += `<div class="analysis-card summary-card"><h3><span class="dot green"></span> Executive Summary</h3><div class="content">${summaryText}</div></div>`;

// Lifestyle
if (data.links) {
  html += `<div class="analysis-card summary-card"><h3><span class="dot green"></span> Lifestyle Recommendations</h3><div class="content">${data.links}</div></div>`;
}
html += `</section>`;

// FLAGS
html += `<section id="flags" class="fade-in">`;
html += `<div class="section-label">Key Flags</div>`;
html += `<div class="section-title">Findings Requiring Attention</div>`;
html += `<div class="section-sub">${flags.length} key flag${flags.length !== 1 ? 's' : ''} identified in your results</div>`;
flags.forEach((f, i) => {
  html += `<div class="analysis-card flag-card"><h3><span class="dot red"></span> Flag ${i+1}</h3><div class="content">${f}</div></div>`;
});
html += `</section>`;

// RECOMMENDATIONS
html += `<section id="recommendations" class="fade-in">`;
html += `<div class="section-label">Clinical Recommendations</div>`;
