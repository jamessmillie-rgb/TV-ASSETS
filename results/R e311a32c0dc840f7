    <div class="count">${gBms.length} markers ${abnLabel} <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
  </div>`;
  html += `<div class="bio-group-body">`;

  gBms.forEach(b => {
    const isAbn = b.within_normal === 'FALSE';
    const isOpt = b.within_optimal === 'TRUE';
    const isQual = b.within_normal === '';
    let badgeClass = 'badge-yellow';
    let badgeText = 'In Range';
    let dotClass = 'dot-yellow';
    if (isAbn) { badgeClass = 'badge-red'; badgeText = 'Outside Range'; dotClass = 'dot-red'; }
    else if (isOpt) { badgeClass = 'badge-green'; badgeText = 'Optimal'; dotClass = 'dot-green'; }
    else if (isQual) { badgeClass = 'badge-blue'; badgeText = b.result || 'N/A'; dotClass = 'dot-green'; }

    let barHTML = '';
    if (b.result_position !== '' && b.lower_normal_position !== '') {
      const rp = parseFloat(b.result_position) * 100;
      const lnp = parseFloat(b.lower_normal_position) * 100;
      const unp = parseFloat(b.upper_normal_position) * 100;
      const lop = b.lower_optimal_position !== '' ? parseFloat(b.lower_optimal_position) * 100 : '';
      const uop = b.upper_optimal_position !== '' ? parseFloat(b.upper_optimal_position) * 100 : '';

      barHTML = `<div class="range-bar-container"><div class="range-bar">`;
      barHTML += `<div class="range-normal" style="left:${lnp}%;width:${unp-lnp}%"></div>`;
      if (lop !== '' || uop !== '') {
        const optLeft = lop !== '' ? lop : lnp;
        const optRight = uop !== '' ? uop : unp;
        barHTML += `<div class="range-optimal" style="left:${optLeft}%;width:${optRight-optLeft}%"></div>`;
      }
      barHTML += `<div class="range-dot ${dotClass}" style="left:${Math.max(0,Math.min(100,rp))}%"></div>`;
      barHTML += `</div></div>`;
    }

    let detailHTML = '';
    if (b.description) {
      detailHTML += `<div class="bio-detail-desc">${b.description}</div>`;
    }
    if (b.lower_normal !== '' || b.upper_normal !== '') {
      detailHTML += `<div class="bio-detail-ranges">`;
      if (b.lower_normal !== '') detailHTML += `<div class="bio-detail-range"><strong>Normal low:</strong> ${b.lower_normal}</div>`;
      if (b.upper_normal !== '') detailHTML += `<div class="bio-detail-range"><strong>Normal high:</strong> ${b.upper_normal}</div>`;
      if (b.lower_optimal !== '') detailHTML += `<div class="bio-detail-range"><strong>Optimal low:</strong> ${b.lower_optimal}</div>`;
      if (b.upper_optimal !== '') detailHTML += `<div class="bio-detail-range"><strong>Optimal high:</strong> ${b.upper_optimal}</div>`;
      detailHTML += `</div>`;
    }
    if (b.low_causes || b.high_causes) {
      detailHTML += `<div class="bio-detail-causes">`;
      if (b.low_causes) detailHTML += `<p><strong>Common causes if low:</strong> ${b.low_causes}</p>`;
      if (b.high_causes) detailHTML += `<p><strong>Common causes if high:</strong> ${b.high_causes}</p>`;
      detailHTML += `</div>`;
    }

    html += `<div class="bio-card" data-status="${isAbn ? 'abnormal' : isOpt ? 'optimal' : isQual ? 'qual' : 'range'}" data-name="${b.name.toLowerCase()}">
      <div class="bio-card-main" onclick="toggleCard(this.parentElement)">
        <div class="bio-card-info">
          <div class="bio-card-name">${b.name}</div>
          <div class="bio-card-result">${b.result} ${b.units || ''}</div>
        </div>
        ${barHTML}
        <span class="bio-card-badge ${badgeClass}">${badgeText}</span>
      </div>
      <div class="bio-detail">${detailHTML}</div>
    </div>`;
  });

  html += `</div></div>`;
});

html += `</section>`;

// FOOTER
html += `<div class="footer">
  <p>TrueVitals Group Ltd · Company No. 16449605</p>
  <p>This report is for informational purposes only and does not constitute medical advice.</p>
  <p><a href="https://www.truevitals.co.uk">truevitals.co.uk</a></p>
</div>`;

main.innerHTML = html;

// Interactions
function toggleGroup(el) { el.classList.toggle('open'); }
function toggleCard(el) { el.classList.toggle('expanded'); }

function setActive(a) {
  document.querySelectorAll('.nav-links a').forEach(l => l.classList.remove('active'));
  a.classList.add('active');
}
function setActiveMob(a) {
  document.querySelectorAll('.mobile-nav a').forEach(l => l.classList.remove('active'));
  a.classList.add('active');
}

function setFilter(btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  filterBiomarkers();
}

function filterBiomarkers() {
  const search = document.querySelector('.bio-search').value.toLowerCase();
  const filter = document.querySelector('.filter-btn.active').dataset.filter;

  document.querySelectorAll('.bio-card').forEach(card => {
    const name = card.dataset.name;
    const status = card.dataset.status;
    let show = true;
    if (search && !name.includes(search)) show = false;
    if (filter === 'abnormal' && status !== 'abnormal') show = false;
    if (filter === 'optimal' && status !== 'optimal') show = false;
    card.style.display = show ? '' : 'none';
  });

  // Hide empty groups
  document.querySelectorAll('.bio-group').forEach(g => {
    const visible = g.querySelectorAll('.bio-card[style=""], .bio-card:not([style])').length;
    g.style.display = visible > 0 ? '' : 'none';
  });
}

// Scroll animations
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

// Update active nav on scroll
const sections = document.querySelectorAll('section');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(s => {
    if (window.scrollY >= s.offsetTop - 120) current = s.id;
  });
  document.querySelectorAll('.nav-links a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
  document.querySelectorAll('.mobile-nav a').forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
});

// DOB GATE
const dobInput = document.getElementById('gate-dob');
const gateError = document.getElementById('gate-error');

dobInput.addEventListener('input', function(e) {
  let v = this.value.replace(/[^\d]/g, '');
  if (v.length > 8) v = v.substring(0, 8);
  let formatted = '';
  if (v.length > 0) formatted = v.substring(0, Math.min(2, v.length));
  if (v.length > 2) formatted += ' / ' + v.substring(2, Math.min(4, v.length));
  if (v.length > 4) formatted += ' / ' + v.substring(4);
  this.value = formatted;
});

dobInput.addEventListener('keydown', function(e) {
  if (e.key === 'Enter') verifyDob();
});

function verifyDob() {
  const entered = dobInput.value.replace(/\s/g, '').replace(/\//g, '/');
  const stored = data.dob;
  const normalize = (d) => {
    let clean = d.replace(/\s/g, '');
    if (/^\d{4}-\d{2}-\d{2}/.test(clean)) {
      const parts = clean.split(/[-T]/);
      return parts[2] + '/' + parts[1] + '/' + parts[0];
    }
    return clean;
  };
  if (normalize(entered) === normalize(stored)) {
    document.getElementById('gate').classList.add('gate-hidden');
    document.getElementById('app-nav').classList.remove('app-hidden');
    document.getElementById('app-mobile-nav').classList.remove('app-hidden');
    document.getElementById('main').classList.remove('app-hidden');
    gateError.style.display = 'none';
  } else {
    gateError.style.display = 'block';
    dobInput.style.borderColor = 'var(--red)';
    setTimeout(() => { dobInput.style.borderColor = ''; }, 2000);
  }
}

dobInput.focus();
</script>
