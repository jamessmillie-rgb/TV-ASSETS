  <button class="filter-btn active" data-filter="all" onclick="setFilter(this)">All</button>
  <button class="filter-btn" data-filter="abnormal" onclick="setFilter(this)">Outside Range</button>
  <button class="filter-btn" data-filter="optimal" onclick="setFilter(this)">Optimal</button>
</div>`;

groupOrder.forEach(gName => {
  const gBms = groups[gName];
  if (!gBms) return;
  const gAbn = gBms.filter(b => b.within_normal === 'FALSE').length;
  const abnLabel = gAbn > 0 ? `<span style="color:var(--red)">${gAbn} flagged</span>` : '';

  html += `<div class="bio-group" data-group="${gName}">`;
  html += `<div class="bio-group-header" onclick="toggleGroup(this.parentElement)">
